# Clanker Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Azure OpenAI (Recommended for enterprise use)
# =============================================================================
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# =============================================================================
# Anthropic (for Claude models)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# OpenAI (for GPT models via OpenAI directly)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# Default Provider Override (optional)
# =============================================================================
# CLANKER_MODEL__PROVIDER=azure
# CLANKER_MODEL__NAME=gpt-4o
# CLANKER_MODEL__AZURE__API_VERSION=2024-02-15-preview
